# Copy to .env and fill in. .env is gitignored.
#
# No Anthropic/OpenAI keys are required — the agent runs through your local
# `claude` CLI, which uses your Claude Code Max subscription.

SUPABASE_URL=https://gujgtjqqurildqurpffh.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Your Supabase auth.users.id (UUID). Same value as VITE_SUNDAY_ADMIN_USER_ID.
SUNDAY_USER_ID=

# Claude Code CLI. "claude" works if it's on PATH; otherwise absolute path.
CLAUDE_CODE_BIN=claude

# Optional
SUNDAY_USER_TIMEZONE=America/Chicago
SUNDAY_POLL_INTERVAL_MS=4000          # code dispatch polling
SUNDAY_CHAT_POLL_INTERVAL_MS=5000     # chat fallback polling
SUNDAY_SYNTHESIS_HOUR_LOCAL=23        # hour (24h) in local tz when nightly synthesis fires

# Optional — only needed for the home_assistant_* tools.
HOME_ASSISTANT_URL=
HOME_ASSISTANT_TOKEN=

# Optional — Personal Access Token for the GitHub integration.
# Needs the `repo` scope (read) at minimum. Without this, the Projects page
# won't show GitHub repos and the github_* MCP tools will error.
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=
# Local directory where you clone repos. Used as default repo_path when Sunday
# promotes a GitHub repo to a tracked project. Defaults to ~/WebstormProjects.
GITHUB_CLONE_BASE=/Users/trentontaylor/WebstormProjects
# How often the daemon refreshes the GitHub repo cache (milliseconds).
SUNDAY_GITHUB_SYNC_INTERVAL_MS=900000
