# Copy this to .env.local for local development.
# In production these get set in Vercel's environment variables UI.

# ----------------------------------------------------------------------------
# Supabase — required for the main site (client portal, admin panel) AND Sunday
# ----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://gujgtjqqurildqurpffh.supabase.co
VITE_SUPABASE_ANON_KEY=

# ----------------------------------------------------------------------------
# Sunday (admin-only agent) — UUID of the admin auth.users.id.
# Sunday surfaces (/sunday/*) only render for this user. Get this UUID by
# running `select auth.uid();` in the Supabase SQL editor while signed in.
# The same UUID must also be set as SUNDAY_ADMIN_USER_ID in edge function
# secrets so the server-side guard agrees.
# ----------------------------------------------------------------------------
VITE_SUNDAY_ADMIN_USER_ID=
