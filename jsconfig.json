{
  "compilerOptions": {
    "baseUrl": "src",
    "paths": {
      "@components/*": ["app/components/*"],
      "@hooks/*": ["app/hooks/*"],
      "@views/*": ["app/views/*"],
      "@constants/*": ["app/constants/*"],
      "@data/*": ["app/data/*"],
      "@utils/*": ["app/utils/*"],
      "@app/*": ["app/*"]
    }
  },
  "include": ["src"]
}
