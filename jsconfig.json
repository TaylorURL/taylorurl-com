{
  "compilerOptions": {
    "baseUrl": "src",
    "paths": {
      "@components/*": [
        "app/components/*"
      ],
      "@hooks/*": [
        "app/hooks/*"
      ],
      "@views/*": [
        "app/views/*"
      ],
      "@constants/*": [
        "app/constants/*"
      ],
      "@app/*": [
        "app/*"
      ]
    }
  },
  "include": [
    "src"
  ]
}

